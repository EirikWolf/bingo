rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'superadmin';
    }

    function getLocationData(locationId) {
      return get(/databases/$(database)/documents/locations/$(locationId)).data;
    }

    function isLocationAdmin(locationId) {
      return isAuthenticated() && (
        request.auth.uid in getLocationData(locationId).adminUids
        || isSuperAdmin()
      );
    }

    function getGameData(locationId, gameId) {
      return get(/databases/$(database)/documents/locations/$(locationId)/games/$(gameId)).data;
    }

    // ─── Coupon grid validation ────────────────────────────
    // Coupons use flat 25-element arrays (row-major order)
    // index = row * 5 + col
    // Column ranges: B(1-15), I(16-30), N(31-45), G(46-60), O(61-75)

    function isValidCouponGrid(numbers) {
      return numbers is list
        && numbers.size() == 25
        // Free cell at index 12 (row 2, col 2)
        && numbers[12] == 0
        // Column B (indices 0,5,10,15,20) — range 1-15
        && isValidColumnValues(numbers[0], numbers[5], numbers[10], numbers[15], numbers[20], 1, 15)
        // Column I (indices 1,6,11,16,21) — range 16-30
        && isValidColumnValues(numbers[1], numbers[6], numbers[11], numbers[16], numbers[21], 16, 30)
        // Column N (indices 2,7,*12*,17,22) — range 31-45, skip index 12 (free)
        && isValidNColumn(numbers[2], numbers[7], numbers[17], numbers[22], 31, 45)
        // Column G (indices 3,8,13,18,23) — range 46-60
        && isValidColumnValues(numbers[3], numbers[8], numbers[13], numbers[18], numbers[23], 46, 60)
        // Column O (indices 4,9,14,19,24) — range 61-75
        && isValidColumnValues(numbers[4], numbers[9], numbers[14], numbers[19], numbers[24], 61, 75);
    }

    function isValidColumnValues(a, b, c, d, e, min, max) {
      return a is int && b is int && c is int && d is int && e is int
        && a >= min && a <= max
        && b >= min && b <= max
        && c >= min && c <= max
        && d >= min && d <= max
        && e >= min && e <= max
        && a != b && a != c && a != d && a != e
        && b != c && b != d && b != e
        && c != d && c != e
        && d != e;
    }

    function isValidNColumn(a, b, d, e, min, max) {
      // N-column has 4 values (row 0,1,3,4) — row 2 is free cell
      return a is int && b is int && d is int && e is int
        && a >= min && a <= max
        && b >= min && b <= max
        && d >= min && d <= max
        && e >= min && e <= max
        && a != b && a != d && a != e
        && b != d && b != e
        && d != e;
    }

    function isValidMarkedGrid(marked) {
      return marked is list
        && marked.size() == 25
        && marked[12] == true;
    }

    // ─── Users ─────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && isOwner(userId)
        && request.resource.data.role == 'player'
        && request.resource.data.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'createdAt']);

      // Owner can update own fields except role, uid, email
      allow update: if isAuthenticated()
        && isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;

      // Superadmin can update anything including role
      allow update: if isSuperAdmin();

      allow delete: if false;

      // ─── FCM Tokens ───────────────────────────────────
      match /fcmTokens/{tokenId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ─── Locations ─────────────────────────────────────────

    match /locations/{locationId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin();
      allow update: if isLocationAdmin(locationId);
      allow delete: if isSuperAdmin();

      // ─── Location meta (stats — written by Cloud Functions) ──

      match /meta/{docId} {
        allow read: if isAuthenticated();
        allow write: if false; // Only Cloud Functions write stats
      }

      // ─── Leaderboard (written by Cloud Functions) ─────────

      match /leaderboard/{userId} {
        allow read: if isAuthenticated();
        allow write: if false; // Only Cloud Functions update leaderboard
      }

      // ─── Games ───────────────────────────────────────────

      match /games/{gameId} {
        allow read: if isAuthenticated();

        allow create: if isLocationAdmin(locationId)
          && request.resource.data.status == 'setup'
          && request.resource.data.drawnNumbers.size() == 0
          && request.resource.data.winners.size() == 0
          && request.resource.data.keys().hasAll([
              'status', 'drawnNumbers', 'currentNumber', 'totalNumbers',
              'winConditions', 'winners', 'couponCount', 'playerCount',
              'commitment', 'createdAt'
            ]);

        // Admin can update any field
        allow update: if isLocationAdmin(locationId);

        // Players can increment couponCount when game is open for purchase
        allow update: if isAuthenticated()
          && resource.data.status == 'open'
          && request.resource.data.couponCount == resource.data.couponCount + 1
          && request.resource.data.status == resource.data.status
          && request.resource.data.drawnNumbers == resource.data.drawnNumbers
          && request.resource.data.winners == resource.data.winners;

        allow delete: if false;

        // ─── Coupons ─────────────────────────────────────

        match /coupons/{couponId} {
          // Owner or location admin can read
          allow read: if isAuthenticated()
            && (isOwner(resource.data.userId) || isLocationAdmin(locationId));

          allow create: if isAuthenticated()
            && request.resource.data.userId == request.auth.uid
            && getGameData(locationId, gameId).status == 'open'
            && isValidCouponGrid(request.resource.data.numbers)
            && isValidMarkedGrid(request.resource.data.markedCells)
            && request.resource.data.isWinner == false
            && request.resource.data.winCondition == null
            && request.resource.data.paymentMethod in ['commitment', 'vipps']
            && request.resource.data.paymentStatus == 'pending'
            && request.resource.data.keys().hasAll([
                'userId', 'userDisplayName', 'numbers', 'markedCells',
                'commitmentId', 'isWinner', 'winCondition', 'paymentMethod',
                'paymentStatus', 'purchasedAt'
              ]);

          // Coupons are immutable after creation (except admin marking winner)
          allow update: if isLocationAdmin(locationId);

          allow delete: if false;
        }

        // ─── Bingo Claims ────────────────────────────────

        match /bingo_claims/{claimId} {
          // Owner or location admin can read
          allow read: if isAuthenticated()
            && (isOwner(resource.data.userId) || isLocationAdmin(locationId));

          allow create: if isAuthenticated()
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.status == 'pending'
            && request.resource.data.serverValidated == false
            && request.resource.data.serverValidatedCondition == null
            && getGameData(locationId, gameId).status == 'active'
            && request.resource.data.keys().hasAll([
                'userId', 'userDisplayName', 'couponId', 'status',
                'suggestedWinCondition', 'serverValidated',
                'serverValidatedCondition', 'claimedAt'
              ]);

          // Only location admin can approve/reject
          allow update: if isLocationAdmin(locationId)
            && (request.resource.data.status == 'approved' || request.resource.data.status == 'rejected');

          allow delete: if false;
        }
      }
    }

    // ─── Commitments (top-level) ─────────────────────────

    match /commitments/{commitmentId} {
      // Owner, location admin, or superadmin can read
      allow read: if isAuthenticated()
        && (
          isOwner(resource.data.userId)
          || isLocationAdmin(resource.data.locationId)
          || isSuperAdmin()
        );

      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
            'userId', 'userDisplayName', 'locationId', 'locationName',
            'gameId', 'couponId', 'description', 'status', 'createdAt'
          ]);

      // Location admin can update status, but not change userId
      allow update: if isLocationAdmin(resource.data.locationId)
        && request.resource.data.userId == resource.data.userId
        && (request.resource.data.status == 'confirmed' || request.resource.data.status == 'cancelled');

      // Superadmin can update anything
      allow update: if isSuperAdmin();

      // Players cannot change their own commitments
      allow delete: if false;
    }
  }
}
